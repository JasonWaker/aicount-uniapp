{
  "bsonType": "object",
  "required": ["content", "status", "created_at", "updated_at"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "Document id"
    },
    "user_id": {
      "bsonType": "string"
    },
    "type": {
      "bsonType": "string"
    },
    "content": {
      "bsonType": "string"
    },
    "contact": {
      "bsonType": "string"
    },
    "attachments": {
      "bsonType": "array",
      "arrayType": "string"
    },
    "status": {
      "bsonType": "string",
      "enum": ["pending", "processing", "resolved", "closed"],
      "defaultValue": "pending"
    },
    "created_at": {
      "bsonType": "timestamp"
    },
    "updated_at": {
      "bsonType": "timestamp"
    }
  }
}
